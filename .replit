modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "dist/server.js"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
TELEGRAM_WEBHOOK_BASE_URL = "https://e1857b64-254a-40dd-9340-0e80e943d264-00-23dju2t82ldcr.worf.replit.dev"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
